model Album {
  id      Int     @id @default(autoincrement())
  title   String
  year    Int?
  visible Boolean @default(true)
  profileId Int 
  profile   Profile @relation(fields: [profileId], references: [id])

  photos AlbumPhoto[]
  topicId Int 
  topic Topic @relation("AlbumToTopic", fields: [topicId], references: [id])
}