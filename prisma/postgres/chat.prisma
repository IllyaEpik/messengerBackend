model Chat {
  id           BigInt             @id @default(autoincrement())
  name         String?            @db.VarChar(30)
  is_group     Boolean
  avatar       String?            @db.VarChar(100)
  adminId      BigInt?            @map("admin_id")
  admin        User?              @relation("ChatAdmin", fields: [adminId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_chat_admin_id_f1deddb9_fk_user_app_user_id")
  participants ChatParticipants[] @relation("ChatParticipants")
  messages     Message[]

  @@index([adminId], map: "chat_app_chat_admin_id_f1deddb9")
  @@map("chat_app_chat")
}

model Message {
  id           BigInt           @id @default(autoincrement())
  text         String?
  created_at   DateTime         @db.Timestamptz(6)
  chatId       BigInt           @map("chat_id")
  senderId     BigInt?          @map("sender_id")
  chat         Chat             @relation(fields: [chatId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_message_chat_id_a7824698_fk_chat_app_chat_id")
  sender       User?            @relation("sentMessages", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_message_sender_id_03c5fae9_fk_user_app_user_id")
  readers      MessageReaders[]
  messageImage ChatImage[]

  @@index([chatId], map: "chat_app_message_chat_id_a7824698")
  @@index([senderId], map: "chat_app_message_sender_id_03c5fae9")
  @@map("chat_app_message")
}

model ChatParticipants {
  id     BigInt @id @default(autoincrement())
  chatId BigInt @map("chat_id")
  userId BigInt @map("user_id")
  chat   Chat   @relation("ChatParticipants", fields: [chatId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_chat_users_chat_id_5bba5169_fk_chat_app_chat_id")
  user   User   @relation("ChatParticipants", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_chat_users_user_id_7aff58dc_fk_user_app_user_id")

  @@unique([chatId, userId], map: "chat_app_chat_users_chat_id_user_id_b05bfe90_uniq")
  @@index([chatId], map: "chat_app_chat_users_chat_id_5bba5169")
  @@index([userId], map: "chat_app_chat_users_user_id_7aff58dc")
  @@map("chat_app_chat_users")
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model MessageReaders {
  id               BigInt  @id @default(autoincrement())
  messageId       BigInt @map("message_id")
  userId          BigInt @map("user_id")
  message Message @relation(fields: [messageId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_message_rea_message_id_adafa038_fk_chat_app_")
  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_message_readers_user_id_11fb5647_fk_user_app_user_id")

  @@unique([messageId, userId], map: "chat_app_message_readers_message_id_user_id_dfa7b323_uniq")
  @@index([messageId], map: "chat_app_message_readers_message_id_adafa038")
  @@index([userId], map: "chat_app_message_readers_user_id_11fb5647")
  @@map("chat_app_message_readers")
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model ChatImage {
  id               BigInt  @id @default(autoincrement())
  image            String  @db.VarChar(100)
  message_id       BigInt
  chat_app_message Message @relation(fields: [message_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_messageimag_message_id_7967b5cb_fk_chat_app_")

  @@index([message_id], map: "chat_app_messageimage_message_id_7967b5cb")
  @@map("chat_app_messageimage")
}
