model Profile {
    id Int @id @unique @default(autoincrement())
    nickname String
    username String @unique
    userId Int @unique
    user User @relation("profile_user",fields: [userId], references: [id]) 
    birthday DateTime?
    firstName String?
    lastName String?
    electronicSignature String?
    showElectronicSignature Boolean @default(false)
    showNickname Boolean @default(true)
    avatar Avatar[] @relation("avatar_profile")

    albums Album[]
}