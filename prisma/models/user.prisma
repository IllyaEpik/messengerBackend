model User {
    id    Int     @id @default(autoincrement())
    username  String? @unique 
    email String  @unique
    password String
    emailVerification EmailVerification? @relation("UserEmailVerification")
    profile Profile? @relation("UserProfile")
    chats Chat[] @relation("ChatParticipants")
    adminChats Chat[] @relation("ChatAdmin")
    messages Message[] @relation("MessageReaders")
    sentMessages Message[] @relation("sentMessages")
    posts Post[]
    views PostView[]
    likes PostLike[]
    hearts PostHeart[]
}
model EmailVerification {
  id Int @id @default(autoincrement())
  new_email String? @unique
  code String @unique
  expiresAt DateTime
  userId Int @unique
  user User @relation("UserEmailVerification",fields: [userId], references: [id])
}